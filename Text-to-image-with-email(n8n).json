    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen3.5:9b\",\n  \"stream\": false,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert image prompt engineer. Take the user description and rewrite it as a detailed, vivid image generation prompt. Write in flowing descriptive prose. Include subject details, setting, lighting, mood, camera angle, art style. Return ONLY the enhanced prompt. No explanations, no extra text.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $json.chatInput }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        128,
        -272
      ],
      "id": "b043ba7a-35ad-4c88-b792-a495e7c766f1",
      "name": "Enhance Prompt (Qwen)"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8188/prompt",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        624,
        -288
      ],
      "id": "f5247c56-1fa7-41be-b5ae-045a7b08658c",
      "name": "Submit to ComfyUI"
