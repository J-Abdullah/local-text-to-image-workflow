      "name": "Wait",
      "webhookId": ""
    },
    {
      "parameters": {
        "url": "=http://host.docker.internal:8188/history/{{ $('Submit to ComfyUI').first().json.prompt_id }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
